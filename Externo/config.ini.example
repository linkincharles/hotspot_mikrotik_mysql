; ============================================
; Configuração do Hotspot
; Exemplo de configuração - Copie para config.ini e preencha
; ============================================

[database]
db_host = "localhost"
db_port = "3306"
db_user = "seu_usuario"
db_pass = "sua_senha"
db_name = "nome_do_banco"

[hotspot]
hotspot_name = "WiFi GRÁTIS"
hotspot_logo = "logo.png"
hotspot_bg_image = "bg.jpg"
hotspot_primary_color = "#667eea"
hotspot_secondary_color = "#764ba2"
external_login_url = "https://seu-dominio.com.br/login.php"
mikrotik_ip = "192.168.1.1"
mikrotik_api_port = "8728"
mikrotik_api_user = "admin"
mikrotik_api_pass = "sua_senha"

[admin]
admin_user = "admin"
admin_pass = ""
